<UserControl x:Class="NuGetManagerSlim.ToolWindows.NuGetQuickManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:NuGetManagerSlim.ViewModels"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             vsui:ThemedDialogStyleLoader.UseDefaultThemedDialogStyles="True"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             TextElement.Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             TextElement.FontFamily="{DynamicResource VsFont.EnvironmentFontFamily}"
             TextElement.FontSize="{DynamicResource VsFont.EnvironmentFontSize}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="420">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Themed Button used everywhere in the tool window. -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonHoverBrushKey}}" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderHoverBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonHoverTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonPressedBrushKey}}" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderPressedBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonPressedTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonDisabledBrushKey}}" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderDisabledBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonDisabledTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Borderless icon-only button for the install/update glyph in each row. -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.AccentMediumBrushKey}}" />
        </Style>

        <!-- Themed ComboBox/CheckBox/Expander/Hyperlink styles are supplied by
             vsui:ThemedDialogStyleLoader.UseDefaultThemedDialogStyles on the root. -->

        <!-- Compact, low-key Expander toggle: a small chevron instead of the loud
             white circle that the default WPF template renders. -->
        <Style x:Key="ExpanderChevronToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="Chevron"
                                      Width="9" Height="9"
                                      Stretch="Uniform"
                                      Data="M 0 0 L 4 4 L 0 8 Z"
                                      Fill="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                      VerticalAlignment="Center" />
                                <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chevron" Property="Data"
                                        Value="M 0 0 L 8 0 L 4 4 Z" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chevron" Property="Fill"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Top"
                                          Style="{StaticResource ExpanderChevronToggleStyle}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding Header}"
                                          Foreground="{TemplateBinding Foreground}" />
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="14,2,0,0"
                                              Visibility="Collapsed" />
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" />
            <Setter Property="FontSize" Value="11" />
            <Style.Triggers>
                <!-- Switch muted text to the selection text color while the row is selected
                     so it stays readable against the selection background. -->
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveTextBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VersionBadgeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveTextBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Pill that marks installed packages in the Browse list. Hidden in
             the Installed scope (where every row is installed and the badge
             would just be noise). -->
        <Style x:Key="InstalledPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#2E8B57" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInstalled}" Value="True" />
                        <Condition Binding="{Binding DataContext.FilterInstalled, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Themed ListBox/ListBoxItem so selection follows the active VS theme. -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Padding" Value="0,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <!-- Use the lighter inactive selection brush so the blue update
                                     arrow icon stays visible on selected rows. -->
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveTextBrushKey}}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:TreeViewColors.SelectedItemInactiveTextBrushKey}}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocallyVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" MinHeight="100" MaxHeight="350" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Project scope, view-mode toggle, prerelease toggle, search and refresh
             all live in the native VS toolbar / search bar provided by the ToolWindowPane. -->

        <!-- E: Package list -->
        <Grid Grid.Row="0">
            <!-- Loading indicator -->
            <TextBlock Text="Loading…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

            <!-- Skeleton placeholder rows: shown while a remote search is in flight
                 and we don't yet have results to render. Visually communicates that
                 work is happening without the "empty list with a spinner" pause. -->
            <ItemsControl Focusable="False" IsHitTestVisible="False"
                          Visibility="{Binding ShowSkeleton, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsSource>
                    <x:Array Type="{x:Type sys:Object}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                        <sys:Object /><sys:Object /><sys:Object /><sys:Object />
                        <sys:Object /><sys:Object /><sys:Object /><sys:Object />
                    </x:Array>
                </ItemsControl.ItemsSource>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3" Height="46">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Rectangle Grid.Column="0" Grid.RowSpan="2" Width="28" Height="28"
                                       VerticalAlignment="Center" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource {x:Static vsshell:VsBrushes.PanelHyperlinkKey}}"
                                       Opacity="0.18" />
                            <Rectangle Grid.Column="1" Grid.Row="0" Height="11"
                                       Margin="8,4,40,2" HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource {x:Static vsshell:VsBrushes.PanelHyperlinkKey}}"
                                       Opacity="0.22" />
                            <Rectangle Grid.Column="1" Grid.Row="1" Height="9"
                                       Margin="8,2,80,4" HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource {x:Static vsshell:VsBrushes.PanelHyperlinkKey}}"
                                       Opacity="0.14" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding EmptyStateMessage}" TextAlignment="Center" TextWrapping="Wrap" Margin="20" />
            </StackPanel>

            <!-- Package list -->
            <ListBox x:Name="PackageListBox"
                     ItemsSource="{Binding Packages}"
                     SelectedItem="{Binding SelectedPackage}"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="PackageListBox_SelectionChanged"
                     Visibility="{Binding HasPackages, Converter={StaticResource BoolToVis}}"
                     AutomationProperties.Name="Package list"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PackageRowViewModel}">
                        <Grid Margin="4,3" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <!-- Package icon (with NuGetNoColor fallback when missing or fails to load). No border / chrome.
                                 The fallback CrispImage is hidden whenever the package icon Image is shown so the
                                 placeholder doesn't bleed through transparent PNGs. -->
                            <Grid Grid.Column="0" Grid.RowSpan="2"
                                  Width="32" Height="32"
                                  VerticalAlignment="Center">
                                <imaging:CrispImage Width="20" Height="20"
                                                    Moniker="{x:Static catalog:KnownMonikers.NuGetNoColor}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <imaging:CrispImage.Style>
                                        <Style TargetType="imaging:CrispImage">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </imaging:CrispImage.Style>
                                </imaging:CrispImage>
                                <Image Source="{Binding Icon, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                                       Width="28" Height="28"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                                       ImageFailed="PackageIcon_ImageFailed" />
                            </Grid>

                            <!-- Package ID + version -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="8,0,0,0">
                                <TextBlock Text="{Binding PackageId}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Border Style="{StaticResource InstalledPillStyle}"
                                        ToolTip="This package is installed in the current project">
                                    <TextBlock Text="Installed"
                                               Foreground="White"
                                               FontSize="9"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text=" [pre]" FontSize="10" VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                           Visibility="{Binding IsPrerelease, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <!-- Downloads + author. The update arrow icon in the action area
                                 already signals that a newer version is available, and the
                                 selected row's detail pane shows the precise versions, so we
                                 use this row for popularity context instead. -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="8,1,0,0">
                                <TextBlock Text="{Binding DownloadCountDisplay}"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding AuthorDisplay}"
                                           Style="{StaticResource MutedTextStyle}" Margin="6,0,0,0" />
                            </StackPanel>

                            <!-- Quick action area. The update button is always visible when an
                                 update is available (so users can spot updateable packages at a
                                 glance) while install / uninstall remain hover-only to keep the
                                 row visually quiet at rest. -->
                            <StackPanel Grid.Column="2" Grid.RowSpan="2" Orientation="Vertical"
                                        VerticalAlignment="Center" Margin="4,0,4,0">
                                <!-- Always-visible update affordance. Doubles as a status badge so the
                                     row reads as 'has update' even when not hovered, and as a one-click
                                     update target when the user does hover. Hidden during an in-flight
                                     operation so the spinner in the hover zone owns the visual state. -->
                                <Button Command="{Binding DataContext.QuickUpdateCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Update to latest version"
                                        AutomationProperties.Name="{Binding UpdateButtonAccessibleName}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasUpdate}" Value="True" />
                                                        <Condition Binding="{Binding IsOperationInProgress}" Value="False" />
                                                        <Condition Binding="{Binding DataContext.IsReadOnlyScope, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <imaging:CrispImage Width="16" Height="16"
                                                        Moniker="{x:Static catalog:KnownMonikers.StatusUpdateAvailable}" />
                                </Button>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Hidden" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <!-- Stay visible while an install/update/uninstall is running so
                                                 the spinner is always shown (even after the mouse leaves). -->
                                            <DataTrigger Binding="{Binding IsOperationInProgress}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- Spinner shown while a row-level operation is running. Replaces the
                                     three action buttons with a single rotating progress glyph.
                                     Vector-drawn (Ellipse with dashed stroke) so it stays crisp under
                                     the continuous RotateTransform; CrispImage's pixel snapping makes
                                     raster icons look blurry while spinning. -->
                                <Grid Width="20" Height="20"
                                      Visibility="{Binding IsOperationInProgress, Converter={StaticResource BoolToVis}}"
                                      ToolTip="Working...">
                                    <Ellipse Width="14" Height="14"
                                             Stroke="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                             StrokeThickness="2"
                                             StrokeDashArray="3 1.5"
                                             StrokeDashCap="Round"
                                             Opacity="0.85"
                                             RenderTransformOrigin="0.5,0.5"
                                             SnapsToDevicePixels="False"
                                             UseLayoutRounding="False">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="QuickActionSpinnerRotate" Angle="0" />
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="QuickActionSpinnerRotate"
                                                            Storyboard.TargetProperty="Angle"
                                                            From="0" To="360" Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </Grid>

                                <Button Command="{Binding DataContext.QuickInstallCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Install latest version"
                                        AutomationProperties.Name="{Binding InstallButtonAccessibleName}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding CanQuickInstall}" Value="True" />
                                                        <Condition Binding="{Binding IsOperationInProgress}" Value="False" />
                                                        <Condition Binding="{Binding DataContext.IsReadOnlyScope, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <imaging:CrispImage Width="16" Height="16"
                                                        Moniker="{x:Static catalog:KnownMonikers.CloudDownload}" />
                                </Button>
                                <Button Command="{Binding DataContext.QuickUninstallCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Uninstall package"
                                        AutomationProperties.Name="{Binding UninstallButtonAccessibleName}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding CanQuickUninstall}" Value="True" />
                                                        <Condition Binding="{Binding IsOperationInProgress}" Value="False" />
                                                        <Condition Binding="{Binding DataContext.IsReadOnlyScope, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <imaging:CrispImage Width="16" Height="16"
                                                        Moniker="{x:Static catalog:KnownMonikers.Remove}" />
                                </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Section headers. The default "Packages" group's header is
                     collapsed so non-installed Browse rows render as a flat
                     list. The "Installed" header is also collapsed when the
                     user is on the Installed scope (every row is installed,
                     so the header would be redundant). -->
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontStyle="Italic">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                            <Setter Property="Padding" Value="4,8,0,2" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Name}" Value="Packages">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="Padding" Value="0" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Name}" Value="Installed">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="Padding" Value="0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>

            <!-- Remote-loading spinner at bottom -->
            <Border VerticalAlignment="Bottom" Padding="4"
                    Visibility="{Binding IsRemoteLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#x27F3; Loading remote results…"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center" />
            </Border>
        </Grid>

        <!-- Splitter between list and detail -->
        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource {x:Static vsui:EnvironmentColors.PanelSeparatorBrushKey}}"
                      ShowsPreview="True" />

        <!-- F: Detail pane -->
        <Border Grid.Row="2" BorderThickness="0,1,0,1"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                Visibility="{Binding HasSelectedPackage, Converter={StaticResource BoolToVis}}">
            <ScrollViewer x:Name="DetailScrollViewer" VerticalScrollBarVisibility="Auto" Padding="8,6">
                <StackPanel>
                    <!-- Package title + version dropdown + install button -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Detail.PackageId}"
                                   FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Detail.AvailableVersions}"
                                  SelectedItem="{Binding Detail.SelectedVersion}"
                                  MinWidth="100" Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  AutomationProperties.Name="Package version" />
                        <Button Grid.Column="2"
                                Command="{Binding Detail.InstallCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                Margin="4,0,0,0"
                                ToolTip="Install"
                                AutomationProperties.Name="Install package"
                                Visibility="{Binding Detail.CanInstall, Converter={StaticResource BoolToVis}}">
                            <imaging:CrispImage Width="16" Height="16"
                                                Moniker="{x:Static catalog:KnownMonikers.CloudDownload}" />
                        </Button>
                    </Grid>

                    <!-- Description -->
                    <TextBlock Text="{Binding Detail.Description}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               LineHeight="18"
                               LineStackingStrategy="BlockLineHeight"
                               Margin="0,2,0,10" />

                    <!-- Metadata row -->
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock Style="{StaticResource MutedTextStyle}" Margin="0,0,12,0">
                            <Run Text="License: " />
                            <Hyperlink Command="{Binding Detail.OpenLicenseCommand}">
                                <Run Text="{Binding Detail.License}" />
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedTextStyle}" Margin="0,0,12,0">
                            <Run Text="Downloads: " /><Run Text="{Binding Detail.DownloadCountDisplay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedTextStyle}" Margin="0,0,12,0">
                            <Run Text="Authors: " /><Run Text="{Binding Detail.Authors}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedTextStyle}" Margin="0,0,12,0"
                                   Visibility="{Binding Detail.HasPublished, Converter={StaticResource BoolToVis}}">
                            <Run Text="Last updated: " /><Run Text="{Binding Detail.PublishedDisplay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Visibility="{Binding Detail.HasProjectUrl, Converter={StaticResource BoolToVis}}">
                            <Hyperlink Command="{Binding Detail.OpenProjectUrlCommand}"
                                       ToolTip="{Binding Detail.ProjectUrl}">
                                <Run Text="Project website" />
                            </Hyperlink>
                        </TextBlock>
                    </WrapPanel>

                    <!-- Action buttons (Update All Projects). Install is moved
                         up next to the version dropdown; Update and Uninstall
                         are intentionally omitted from the detail pane (the
                         row's inline Update / Uninstall icon buttons are the
                         canonical entry points). -->
                    <WrapPanel Margin="0,0,0,6">
                        <Button Content="Update All Projects"
                                Command="{Binding Detail.UpdateAllProjectsCommand}"
                                Padding="10,4" Margin="0,0,4,0"
                                Visibility="{Binding Detail.CanUpdateAllProjects, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.Name="Update package in all projects" />
                    </WrapPanel>

                    <!-- Dependency tree (grouped by target framework) -->
                    <Expander Header="Dependencies" IsExpanded="False">
                        <ItemsControl ItemsSource="{Binding Detail.DependencyGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2,0,4">
                                        <TextBlock Text="{Binding Header}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Margin="0,0,0,2" />
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="12,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding NameAndVersion}"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Margin="0,1" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- G: Status bar -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                Padding="6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding FilterPrerelease}"
                          Content="Include prerelease"
                          VerticalAlignment="Center"
                          Margin="4,0,8,0"
                          FontSize="11"
                          Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                          AutomationProperties.Name="Include prerelease versions" />
            </Grid>
        </Border>

        <!-- H: Operation log panel (toggled by status-bar "View log" button) -->
        <Border Grid.Row="4" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                Padding="6,4"
                MaxHeight="180"
                Visibility="{Binding IsLogOpen, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Operation log"
                               FontWeight="SemiBold"
                               FontSize="11" />
                    <Button Grid.Column="1"
                            Content="Close"
                            Command="{Binding ToggleLogCommand}"
                            Padding="8,2"
                            FontSize="11"
                            AutomationProperties.Name="Close operation log" />
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding OperationLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
